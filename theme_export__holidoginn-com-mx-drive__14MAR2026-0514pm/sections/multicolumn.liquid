<div style="background-color: #e74c3c; color: white; padding: 30px; border-radius: 20px;">
  <h2 style="text-align:center;">¿Cuánto alimento debes dar a tu perro?</h2>

  <label for="peso">Peso de tu perro:</label>
  <input type="range" id="peso" min="1" max="50" value="2" oninput="actualizar()">
  <span id="pesoValor">2kg</span>
  <br><br>

  <label for="actividad">Nivel de Actividad:</label>
  <input type="range" id="actividad" min="1" max="3" value="1" oninput="actualizar()">
  <span id="actividadValor">Nada Activo</span>
  <br><br>

  <strong>Cantidad de comida:</strong>
  <div id="resultado" style="font-size: 30px; background:white; color:#333; display:inline-block; padding: 10px; border-radius: 10px;">250gr</div>
</div>

<script>
  function actualizar() {
    const peso = parseInt(document.getElementById("peso").value);
    const actividad = parseInt(document.getElementById("actividad").value);

    let actividadTexto = ["Nada Activo", "Activo", "Muy Activo"];
    document.getElementById("pesoValor").innerText = peso + "kg";
    document.getElementById("actividadValor").innerText = actividadTexto[actividad - 1];

    // Fórmula ejemplo: más peso y más actividad = más comida
    let comida = 100 + (peso * 50) + ((actividad - 1) * 50);
    document.getElementById("resultado").innerText = Math.round(comida) + "gr";
  }

  actualizar();
</script>
